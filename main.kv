<TooltipMDIconButton@MDIconButton+MDTooltip>

<DrinkButton>:
    orientation: 'vertical'
    size_hint_y: None
    height: '56dp'
    
    Button:
        text: root.drink_text
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        padding: 15, 10
        background_color: [0.15, 0.15, 0.15, 1]
        background_normal: ''
        color: [1, 1, 1, 1]
        font_size: '16sp'
        on_press: if root.callback: root.callback()
    
    Widget:
        size_hint_y: None
        height: 1
        canvas.after:
            Color:
                rgba: [0.5, 0.5, 0.5, 1]
            Rectangle:
                pos: self.pos
                size: self.size

<InfoPopup>
    title: ""
    size_hint : 0.9, 0.2

    BoxLayout:
        Button:
            text: "OK"
            on_release: root.dismiss()
     
<InputPopup>
    title: ""
    input_text: input_text
    size_hint : 0.9, 0.2

    BoxLayout:
        orientation: "vertical"
        height: "40dp"

        TextInput:
            id: input_text
            multiline: False
            hint_text: "enter text"
        Button:
            text: "close"
            on_release: root.save_input()

<ConfirmDeletePopup>
    title: ""
    size_hint : 0.9, 0.2

    BoxLayout:
        orientation: "vertical"
        height: "40dp"

        Button:
            text: "Cancel"
            on_release: root.dismiss()
        Button:
            text: "OK"
            on_release: app.root.delete_drink_complete(root, root.parent_popup)

<IngredientSelectPair>
    id: select_pair
    orientation: "horizontal"
    
    Spinner:
        id: amount_input
        text: "1.0oz"
        values: [ "0.1oz", "0.25oz", "0.5oz", "0.75oz", "1.0oz", "1.25oz", "1.5oz", "2.0oz" ]
    MutableSpinner:
        id: ingredient_input
	
<NewDrinkPopup>
    title: "Add or update a drink"
    separator_height: 0
    auto_dismiss: False
    size_hint: 0.8, 0.8
    pos_hint: {"x":0.1, "y":0.1}

    BoxLayout:
        orientation: "vertical"
        size: root.width, root.height

        MDTextField:
            id: name_input
            mode: "fill"
            hint_text: "Drink name"
            max_text_length: 30

        BoxLayout:
            id: spirit_select
            orientation: "vertical"

            BoxLayout:
                orientation: "horizontal"

                MDLabel:
                    color: "white"
                    text: "choose spirits and amounts"
                MDIconButton:
                    icon: "plus"
                    theme_icon_color: "Custom"
                    icon_color: "white"
                    on_release: root.add_spirit_selector()

        BoxLayout:
            id: mixer_select
            orientation: "vertical"

            BoxLayout:
                orientation: "horizontal"

                MDLabel:
                    color: "white"
                    text: "choose mixers and amounts"
                MDIconButton:
                    icon: "plus"
                    theme_icon_color: "Custom"
                    icon_color: "white"
                    on_release: root.add_mixer_selector()

        BoxLayout:
            id: steps_select
            orientation: "vertical"

            BoxLayout:
                orientation: "horizontal"

                MDLabel:
                    color: "white"
                    text: "enter recipie steps"
                MDIconButton:
                    icon: "plus"
                    theme_icon_color: "Custom"
                    icon_color: "white"
                    on_release: root.add_steps_selector()

        BoxLayout:
            id: glass_select
            orientation: "vertical"

            MDLabel:
                color: "white"
                text: "enter glass"
            MutableSpinner:
                id: glass_input

        Button:
            text: "cancel"
            size_hint: 1.0, 0.3
            on_release: root.dismiss()
        Button:
            text: "ok"
            size_hint: 1.0, 0.3
            on_release: root.save_drink()


<DisplayDrinkPopup>
    title: ""
    title_font: "./fonts/PhosphateInline.ttf"
    title_size: "40sp"
    title_color: [0,0,0,1]
    separator_height: 0
    auto_dismiss: False
    size_hint: 0.8, 0.8
    pos_hint: {"x":0.1, "y":0.1}
    details: drink_details
    ounces: drink_ounces
    glass: drink_glass
    background_color: [3,3,3,1]

    BoxLayout:
        orientation: "vertical"
        size: root.width, root.height

        BoxLayout:
            orientation: "horizontal"

            Label:
                id: drink_ounces
                font_size: '40sp'
                color: [0,0,0,1]
                text: ""
                
            SvgWidget:
                id: drink_glass
                source: "./images/coupe-glass.svg"
            
        Label:
            id: drink_details
            color: [0,0,0,1]
            text_size: self.size
            halign: "left"
            text: ""

        BoxLayout:
            orientation: "horizontal"

            MDIconButton:
                icon: "pencil"
                theme_icon_color: "Custom"
                icon_color: "black"
                on_release: app.root.edit_drink(root.name, root)

            MDIconButton:
                icon: "delete"
                theme_icon_color: "Custom"
                icon_color: "black"
                on_release: app.root.delete_drink_confirm(root.name, root)

            MDIconButton:
                icon: "arrow-left"
                theme_icon_color: "Custom"
                icon_color: "black"
                on_release: root.dismiss()

<HomeScreen>:
    id: home_screen
    orientation: "vertical"
    filter: filter_input
    drink_list: drink_list_view
    padding: 10
    spacing: 10
    
    canvas.before:
        Color:
            rgba: [0.1, 0.1, 0.1, 1]
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        size_hint_y: None
        height: "40dp"
 
        MDTextField:
            id: filter_input
            mode: 'rectangle'
            hint_text: "enter keywords"
            multiline: False
            on_text_validate: root.run_filter()
            icon_left: 'magnify'
            theme_cls: app.theme_cls
            line_color_normal: [0.7, 0.7, 0.7, 1]
            line_color_focus: [1, 1, 1, 1]
            hint_text_color_normal: [0.7, 0.7, 0.7, 1]
            hint_text_color_focus: [1, 1, 1, 1]
            text_color_normal: [1, 1, 1, 1]
            text_color_focus: [1, 1, 1, 1]
            fill_color_normal: [0.15, 0.15, 0.15, 0.5]
            fill_color_focus: [0.2, 0.2, 0.2, 0.7]
            icon_left_color: [1, 1, 1, 1]
	    
    RecycleView:
        id: drink_list_view
        size_hint_y: 9
        viewclass: 'DrinkButton'
        RecycleBoxLayout:
            default_size: None, dp(57)
            default_size_hint: 1, None
            size_hint_y: None
            height: self.minimum_height
            orientation: 'vertical'
            spacing: 0

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 1

        TooltipMDIconButton:
            icon: "plus"
            tooltip_text: "new drink"
            theme_icon_color: "Custom"
            icon_color: [1, 1, 1, 1]
            on_release: root.input_new_drink()

        TooltipMDIconButton:
            icon: "refresh"
            tooltip_text: "refresh db from json"
            theme_icon_color: "Custom"
            icon_color: [1, 1, 1, 1]
            on_release: root.choose_json_import_file()
         
        TooltipMDIconButton:
            icon: "export"
            tooltip_text: "export db to json"
            theme_icon_color: "Custom"
            icon_color: [1, 1, 1, 1]
            on_release: root.export_to_json()

